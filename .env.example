# Server
PORT=8080
NODE_ENV=production

# PostgreSQL (Supabase)
DATABASE_URL=
# Or use individual fields if you prefer

# Redis (optional - skip if not using)
REDIS_URL=

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# JWT Secret
JWT_SECRET=
JWT_EXPIRES_IN=7d

# CORS - allow frontend domains
CORS_ORIGIN=

# Admin bootstrap
ADMIN_EMAIL=
ADMIN_PASSWORD=